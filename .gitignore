# Workspace-local Claude settings (per-machine permissions)
.claude/settings.local.json

# Local agent/editor integration folders: keep local, not in git
.claude/
rad-mcp-server/.claude-plugin/
.vscode/
rad-mcp-server/.vscode/

# Python
__pycache__/
*.pyc

# OS noise
Thumbs.db
desktop.ini

# PDFs are never committed (large binaries) — manuals live locally under
# rad-mcp-server/manuals/; the extracted markdown under
# skills/rad-cli-operations/references/manual-<family>/ is committed instead
*.pdf
*.PDF

# Vendor MIB source sets (large; MIBs2 is the fuller RAD kit) — same pattern
# as the manual PDFs: sources stay local, the COMPILED symbolic map
# (skills/rad-cli-operations/references/snmp-oid-map.json) is committed
MIBS/
MIBs2/
*.mib
*.MIB

# Source spreadsheets dropped at the repo root for one-off eval work — not
# project artifacts, don't commit (Excel's own lock-file too)
/*.xlsx
/~$*.xlsx

# Personal device inventory — never ships with the repo; clones start from
# inventory.example.yaml (or let add_device create the file). Backups too.
rad-mcp-server/inventory.yaml
inventory_bck.yaml

# Personal workspace MCP config (may hold a live bearer token) — the install
# scripts (scripts/install/skills_and_mcp/) generate it instead
.vscode/mcp.json

# One-off proposal drafts at the repo root — personal working files
/etx1p-l2tpv3-proposal.md
/etx1p-l2tpv3-proposal.html

# Local Codex setup notes (workspace-private)
/README-codex-mcp-skills.md

# TLS artifacts (local-only)
*.crt
*.key
