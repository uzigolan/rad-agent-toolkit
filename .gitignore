# Workspace-local Claude settings (per-machine permissions)
.claude/settings.local.json

# Python
__pycache__/
*.pyc

# OS noise
Thumbs.db
desktop.ini

# Device manual PDFs (large binaries) — the extracted markdown under
# skills/rad-cli-operations/references/manual-<family>/ is committed instead
rad-mcp-server/manuals/*.pdf

# Source spreadsheets dropped at the repo root for one-off eval work — not
# project artifacts, don't commit (Excel's own lock-file too)
/*.xlsx
/~$*.xlsx
